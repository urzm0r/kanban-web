generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Board {
  id        String   @id @default(uuid())
  title     String
  lists     List[]
  createdAt DateTime @default(now())
}

model List {
  id      String @id @default(uuid())
  title   String
  order   Int
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId String
  cards   Card[]
}

model Card {
  id         String   @id @default(cuid())
  content    String
  order      Int
  listId     String
  list       List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  lockedBy   String?  
  lockedAt   DateTime? 
}
